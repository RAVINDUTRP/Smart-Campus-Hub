# Copy this file to backend/.env.shared and set real values.
# All team members must use the same values to share one database.
DB_URL=jdbc:postgresql://your-host:5432/smartcampus
DB_USERNAME=smartcampus_user
DB_PASSWORD=change_me

# Optional Module E auth configuration.
# Keep these in backend/.env.shared only if the whole team uses the same OAuth setup.
# Prefer backend/.env for local OAuth overrides when running scripts/run_backend_shared.sh.
SECURITY_OAUTH2_ENABLED=false
SECURITY_OAUTH2_REGISTRATION_ID=google
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
BACKEND_BASE_URL=http://localhost:8080
FRONTEND_SUCCESS_URL=http://localhost:5173/
SECURITY_ADMIN_EMAILS=admin@smartcampus.local
SECURITY_TECHNICIAN_EMAILS=tech1@smartcampus.local
